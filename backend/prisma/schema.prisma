generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Category {
  electronics
  men
  women
  jwellery
}

model User {
  id       Int      @id @default(autoincrement())
  name     String
  email    String   @unique
  password String

  products Product[]
  cart     Cart[]
}

model Product {
  id          Int     @id @default(autoincrement())
  title       String
  price       Float
  description String?
  category    Category
  image       String?
  is_active   Boolean @default(true)

  user_id Int
  user    User @relation(fields: [user_id], references: [id])
  cart    Cart[]
}

model Cart{
  userId     Int
  productId  Int
  quantity   Int @default(1)

  user       User    @relation(fields: [userId], references: [id])
  product    Product @relation(fields: [productId], references: [id])

  @@id([userId, productId])
}