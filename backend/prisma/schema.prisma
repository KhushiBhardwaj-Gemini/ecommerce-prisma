generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int      @id @default(autoincrement())
  name     String
  email    String   @unique
  password String

  products Product[]
}

model Product {
  id          Int     @id @default(autoincrement())
  title       String
  price       Float
  description String?
  category    String
  image       String
  is_active   Boolean @default(true)

  user_id Int
  user    User @relation(fields: [user_id], references: [id])
}